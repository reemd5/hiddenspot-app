<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- Image -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="280dp">

            <ImageView
                android:id="@+id/iv_hero"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@color/muted"/>

            <!-- Gradient overlay -->
            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/gradient_image_overlay"/>

            <!-- Top bar: back + edit + share + favorite -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:paddingLeft="16dp"
                android:paddingRight="16dp"
                android:paddingTop="44dp"
                android:paddingBottom="8dp">

                <ImageButton
                    android:id="@+id/btn_back"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_white"
                    android:src="@drawable/ic_arrow_left"
                    android:padding="8dp"
                    android:tint="@color/foreground"/>

                <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

                <ImageButton
                    android:id="@+id/btn_edit"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_white"
                    android:src="@drawable/ic_edit"
                    android:padding="8dp"
                    android:tint="@color/foreground"
                    android:layout_marginEnd="8dp"
                    android:visibility="gone"/>

                <ImageButton
                    android:id="@+id/btn_share"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_white"
                    android:src="@drawable/ic_share"
                    android:padding="8dp"
                    android:tint="@color/foreground"
                    android:layout_marginEnd="8dp"/>

                <ImageButton
                    android:id="@+id/btn_favorite"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:background="@drawable/bg_circle_white"
                    android:src="@drawable/ic_heart"
                    android:padding="8dp"/>

            </LinearLayout>

            <!-- Image dots indicator -->
            <com.tbuonomo.viewpagerdotsindicator.DotsIndicator
                android:id="@+id/dots_indicator"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:layout_marginBottom="12dp"
                app:dotsColor="@color/primary_foreground"
                app:dotsSize="6dp"
                app:dotsSpacing="4dp"
                app:selectedDotColor="@color/primary_foreground"/>

        </FrameLayout>

        <!-- Main Info Card (overlapping image) -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_marginTop="-24dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Category + Rating row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_category_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp"
                        android:paddingTop="4dp"
                        android:paddingBottom="4dp"
                        android:textColor="@color/primary_foreground"
                        android:textSize="11sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:background="@drawable/bg_chip_active"/>

                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1"/>

                    <!-- Rating chip -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@color/surface_warm"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingLeft="10dp"
                        android:paddingRight="10dp"
                        android:paddingTop="6dp"
                        android:paddingBottom="6dp">

                        <ImageView android:layout_width="14dp" android:layout_height="14dp"
                            android:src="@drawable/ic_star_filled"/>
                        <TextView android:id="@+id/tv_rating"
                            android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:layout_marginStart="4dp" android:textColor="@color/foreground"
                            android:textSize="13sp" android:fontFamily="@font/poppins_bold"/>

                    </LinearLayout>

                </LinearLayout>

                <!-- Place Name -->
                <TextView
                    android:id="@+id/tv_place_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:textColor="@color/foreground"
                    android:textSize="20sp"
                    android:fontFamily="@font/poppins_bold"/>

                <!-- Address -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:gravity="center_vertical" android:orientation="horizontal"
                    android:layout_marginTop="6dp">
                    <ImageView android:layout_width="14dp" android:layout_height="14dp"
                        android:src="@drawable/ic_map_pin" android:tint="@color/muted_foreground"/>
                    <TextView android:id="@+id/tv_address" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:layout_marginStart="6dp"
                        android:textColor="@color/muted_foreground" android:textSize="12sp"
                        android:fontFamily="@font/inter"/>
                </LinearLayout>

                <!-- Phone (shown only if available) -->
                <LinearLayout android:id="@+id/layout_phone"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:gravity="center_vertical" android:orientation="horizontal"
                    android:layout_marginTop="4dp" android:visibility="gone">
                    <ImageView android:layout_width="14dp" android:layout_height="14dp"
                        android:src="@drawable/ic_phone" android:tint="@color/muted_foreground"/>
                    <TextView android:id="@+id/tv_phone" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:layout_marginStart="6dp"
                        android:textColor="@color/secondary" android:textSize="12sp"
                        android:fontFamily="@font/inter"/>
                </LinearLayout>

                <!-- Description -->
                <TextView
                    android:id="@+id/tv_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:textColor="@color/foreground"
                    android:textSize="13sp"
                    android:fontFamily="@font/inter"
                    android:lineSpacingMultiplier="1.5"/>

                <!-- Divider -->
                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:layout_marginTop="16dp" android:layout_marginBottom="12dp"
                    android:background="@color/border_color"/>

                <!-- Vote Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_upvote"
                        style="@style/Widget.HiddenSpot.Button.Outline"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:layout_marginEnd="12dp"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        app:icon="@drawable/ic_thumbs_up"
                        app:iconTint="@color/muted_foreground"
                        android:textColor="@color/muted_foreground"
                        android:textSize="13sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:text="0"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_downvote"
                        style="@style/Widget.HiddenSpot.Button.Outline"
                        android:layout_width="wrap_content"
                        android:layout_height="44dp"
                        android:paddingLeft="16dp"
                        android:paddingRight="16dp"
                        app:icon="@drawable/ic_thumbs_down"
                        app:iconTint="@color/muted_foreground"
                        android:textColor="@color/muted_foreground"
                        android:textSize="13sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:text="0"/>

                </LinearLayout>

                <!-- Action Buttons -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_maps"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="@string/open_in_maps"
                        android:textSize="12sp"
                        android:fontFamily="@font/poppins_semibold"
                        android:backgroundTint="@color/secondary"
                        app:cornerRadius="12dp"
                        app:icon="@drawable/ic_navigation"
                        app:iconTint="@color/primary_foreground"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_call"
                        style="@style/Widget.HiddenSpot.Button.Outline"
                        android:layout_width="48dp"
                        android:layout_height="44dp"
                        android:visibility="gone"
                        app:icon="@drawable/ic_phone"
                        app:iconTint="@color/foreground"/>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Posted By Card -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_marginTop="12dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@color/card">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:padding="12dp">

                <!-- Avatar circle -->
                <FrameLayout
                    android:layout_width="44dp"
                    android:layout_height="44dp">
                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/iv_poster_avatar"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@color/muted"/>
                    <TextView android:id="@+id/tv_poster_initial"
                        android:layout_width="44dp" android:layout_height="44dp"
                        android:gravity="center" android:textColor="@color/primary"
                        android:textSize="16sp" android:fontFamily="@font/poppins_bold"
                        android:background="@color/surface_warm"/>
                </FrameLayout>

                <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:layout_marginStart="12dp"
                    android:orientation="vertical">
                    <TextView android:id="@+id/tv_poster_name"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="@color/foreground" android:textSize="14sp"
                        android:fontFamily="@font/poppins_semibold"/>
                    <TextView android:id="@+id/tv_posted_date"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:layout_marginTop="2dp" android:textColor="@color/muted_foreground"
                        android:textSize="11sp" android:fontFamily="@font/inter"/>
                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_marginTop="12dp"
            app:cardBackgroundColor="@color/card"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:fontFamily="@font/poppins_semibold"
                        android:text="Reviews"
                        android:textColor="@color/foreground"
                        android:textSize="15sp" />

                    <TextView
                        android:id="@+id/tv_review_count"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter"
                        android:textColor="@color/muted_foreground"
                        android:textSize="12sp" />
                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:fontFamily="@font/inter"
                    android:text="Rate this place:"
                    android:textColor="@color/muted_foreground"
                    android:textSize="12sp" />

                <RatingBar
                    android:id="@+id/rating_bar_input"
                    style="?android:attr/ratingBarStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:numStars="5"
                    android:progressTint="@color/star_color"
                    android:rating="0"
                    android:secondaryProgressTint="@color/star_color"
                    android:stepSize="1" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.HiddenSpot.TextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:hint="Write a comment (optional)">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_review_comment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="top"
                        android:inputType="textMultiLine|textCapSentences"
                        android:maxLines="5"
                        android:minLines="2" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_submit_review"
                    android:layout_width="wrap_content"
                    android:layout_height="44dp"
                    android:layout_marginTop="10dp"
                    android:backgroundTint="@color/primary"
                    android:fontFamily="@font/poppins_semibold"
                    android:text="Submit Review"
                    android:textSize="13sp"
                    app:cornerRadius="12dp" />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:layout_marginTop="16dp"
                    android:background="@color/border_color" />

                <TextView
                    android:id="@+id/tv_no_reviews"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/inter"
                    android:gravity="center"
                    android:paddingTop="16dp"
                    android:paddingBottom="8dp"
                    android:text=""
                    android:textColor="@color/muted_foreground"
                    android:textSize="13sp"
                    android:visibility="gone" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_reviews"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
