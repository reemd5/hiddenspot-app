<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Image with overlays -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="176dp">

            <ImageView
                android:id="@+id/iv_place"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@color/muted"/>

            <!-- Category badge (top-left) -->
            <TextView
                android:id="@+id/tv_category_badge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="8dp"
                android:paddingLeft="10dp"
                android:paddingRight="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:textColor="@color/primary_foreground"
                android:textSize="11sp"
                android:fontFamily="@font/poppins_semibold"
                android:background="@drawable/bg_chip_active"/>

            <!-- Favorite button (top-right) -->
            <ImageButton
                android:id="@+id/btn_favorite"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="top|end"
                android:layout_margin="8dp"
                android:background="@drawable/bg_circle_white"
                android:padding="7dp"
                android:src="@drawable/ic_heart"/>

            <ImageButton
                android:id="@+id/btn_delete_post"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_gravity="top|end"
                android:layout_margin="8dp"
                android:background="@drawable/bg_circle_white"
                android:contentDescription="Delete post"
                android:padding="7dp"
                android:src="@android:drawable/ic_menu_delete"
                android:tint="#000000"
                android:visibility="gone" />

        </FrameLayout>

        <!-- Card Content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="12dp">

            <!-- Place name -->
            <TextView
                android:id="@+id/tv_place_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="@color/foreground"
                android:textSize="14sp"
                android:fontFamily="@font/poppins_semibold"
                android:maxLines="1"
                android:ellipsize="end"/>

            <!-- City -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_map_pin"
                    android:tint="@color/muted_foreground"/>

                <TextView
                    android:id="@+id/tv_city"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textColor="@color/muted_foreground"
                    android:textSize="11sp"
                    android:fontFamily="@font/inter"/>

            </LinearLayout>

            <!-- Description -->
            <TextView
                android:id="@+id/tv_description"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:textColor="@color/muted_foreground"
                android:textSize="11sp"
                android:fontFamily="@font/inter"
                android:maxLines="2"
                android:ellipsize="end"
                android:lineSpacingMultiplier="1.4"/>

            <!-- Divider -->
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="10dp"
                android:layout_marginBottom="10dp"
                android:background="@color/border_color"/>

            <!-- Footer: rating + votes -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <!-- Rating -->
                <ImageView
                    android:layout_width="14dp"
                    android:layout_height="14dp"
                    android:src="@drawable/ic_star_filled"/>

                <TextView
                    android:id="@+id/tv_rating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:textColor="@color/foreground"
                    android:textSize="12sp"
                    android:fontFamily="@font/poppins_semibold"/>

                <TextView
                    android:id="@+id/tv_rating_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="2dp"
                    android:textColor="@color/muted_foreground"
                    android:textSize="11sp"
                    android:fontFamily="@font/inter"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"/>

                <!-- Upvotes -->
                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_thumbs_up"
                    android:tint="@color/upvote_green"/>

                <TextView
                    android:id="@+id/tv_upvotes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="3dp"
                    android:layout_marginEnd="12dp"
                    android:textColor="@color/upvote_green"
                    android:textSize="11sp"
                    android:fontFamily="@font/inter"/>

                <!-- Downvotes -->
                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/ic_thumbs_down"
                    android:tint="@color/downvote_red"/>

                <TextView
                    android:id="@+id/tv_downvotes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="3dp"
                    android:textColor="@color/downvote_red"
                    android:textSize="11sp"
                    android:fontFamily="@font/inter"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
