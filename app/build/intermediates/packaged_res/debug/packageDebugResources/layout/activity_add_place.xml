<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">
    <!--  Header  -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_primary"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingLeft="16dp"
        android:paddingTop="44dp"
        android:paddingRight="16dp"
        android:paddingBottom="20dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="12dp"
            android:background="@drawable/bg_circle_white"
            android:padding="8dp"
            android:src="@drawable/ic_arrow_left"
            android:tint="@color/foreground" />

        <TextView
            android:id="@+id/tv_header_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/poppins_bold"
            android:text="@string/add_new_place"
            android:textColor="@color/primary_foreground"
            android:textSize="18sp" />
    </LinearLayout>
    <!--  Scrollable Form  -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">
            <!--  ── Photo Upload ───────────────────────────────────────────  -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:fontFamily="@font/poppins_semibold"
                android:text="Upload a Photo"
                android:textColor="@color/foreground"
                android:textSize="12sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/btn_upload_gallery"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_marginEnd="12dp"
                    android:background="@drawable/bg_upload_dashed"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_upload"
                        android:tint="@color/muted_foreground" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/inter"
                        android:text="@string/upload_label"
                        android:textColor="@color/muted_foreground"
                        android:textSize="10sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/btn_open_camera"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:background="@drawable/bg_upload_dashed"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="vertical">

                    <ImageView
                        android:layout_width="24dp"
                        android:layout_height="24dp"
                        android:src="@drawable/ic_camera"
                        android:tint="@color/muted_foreground" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:fontFamily="@font/inter"
                        android:text="@string/camera_label"
                        android:textColor="@color/muted_foreground"
                        android:textSize="10sp" />
                </LinearLayout>

                <ImageView
                    android:id="@+id/iv_preview"
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_marginStart="12dp"
                    android:background="@drawable/bg_card_rounded"
                    android:scaleType="centerCrop"
                    android:visibility="gone" />
            </LinearLayout>
            <!--  ── Place Name ─────────────────────────────────────────────  -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:fontFamily="@font/poppins_semibold"
                android:text="@string/place_name_label"
                android:textColor="@color/foreground"
                android:textSize="12sp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.HiddenSpot.TextInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_place_name"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:fontFamily="@font/inter"
                    android:hint="@string/place_name_hint"
                    android:inputType="textCapWords"
                    android:textSize="13sp" />
            </com.google.android.material.textfield.TextInputLayout>
            <!--  ── Category ───────────────────────────────────────────────  -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:fontFamily="@font/poppins_semibold"
                android:text="@string/category_label"
                android:textColor="@color/foreground"
                android:textSize="12sp" />

            <androidx.appcompat.widget.AppCompatSpinner
                android:id="@+id/spinner_category"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:layout_marginBottom="16dp"
                android:background="@drawable/bg_card_rounded"
                android:fontFamily="@font/inter"
                android:paddingLeft="12dp"
                android:paddingRight="12dp" />
            <!--  ── City ───────────────────────────────────────────────────  -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:fontFamily="@font/poppins_semibold"
                android:text="@string/city_label"
                android:textColor="@color/foreground"
                android:textSize="12sp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.HiddenSpot.TextInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_city"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:fontFamily="@font/inter"
                    android:hint="@string/city_hint"
                    android:inputType="textCapWords"
                    android:textSize="13sp" />
            </com.google.android.material.textfield.TextInputLayout>
            <!--  ── Address ─────────────────────────────────────────────────  -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:fontFamily="@font/poppins_semibold"
                android:text="@string/address_label"
                android:textColor="@color/foreground"
                android:textSize="12sp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.HiddenSpot.TextInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_address"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:fontFamily="@font/inter"
                    android:hint="@string/address_hint"
                    android:textSize="13sp" />
            </com.google.android.material.textfield.TextInputLayout>
            <!--  Open in Maps hint  -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:layout_marginBottom="16dp"
                android:fontFamily="@font/inter"
                android:text="Enter a full address so others can find it on the map"
                android:textColor="@color/muted_foreground"
                android:textSize="11sp" />
            <!--  ── Phone ───────────────────────────────────────────────────  -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:fontFamily="@font/poppins_semibold"
                android:text="@string/phone_label"
                android:textColor="@color/foreground"
                android:textSize="12sp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.HiddenSpot.TextInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_phone"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:fontFamily="@font/inter"
                    android:hint="@string/phone_hint"
                    android:inputType="phone"
                    android:textSize="13sp" />
            </com.google.android.material.textfield.TextInputLayout>
            <!--  ── Description ─────────────────────────────────────────────  -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:fontFamily="@font/poppins_semibold"
                android:text="@string/description_label"
                android:textColor="@color/foreground"
                android:textSize="12sp" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.HiddenSpot.TextInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/et_description"
                    android:layout_width="match_parent"
                    android:layout_height="120dp"
                    android:fontFamily="@font/inter"
                    android:gravity="top"
                    android:hint="@string/description_hint"
                    android:inputType="textMultiLine"
                    android:minLines="4"
                    android:textSize="13sp" />
            </com.google.android.material.textfield.TextInputLayout>
            <!--  ── Tips Card ────────────────────────────────────────────────  -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="@color/surface_warm"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="8dp"
                        android:fontFamily="@font/poppins_semibold"
                        android:text="💡 Tips for a great submission"
                        android:textColor="@color/foreground"
                        android:textSize="13sp" />

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter"
                        android:lineSpacingMultiplier="1.5"
                        android:text="• Add a clear photo to attract more visitors\n• Use the full street address for accurate map location\n• Write a detailed description of what makes this place special\n• Add a phone number if available"
                        android:textColor="@color/muted_foreground"
                        android:textSize="12sp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <!--  ── Submit Button ───────────────────────────────────────────  -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_submit"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:backgroundTint="@color/primary"
                android:fontFamily="@font/poppins_semibold"
                android:text="@string/submit_btn"
                android:textSize="14sp"
                app:cornerRadius="12dp"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
