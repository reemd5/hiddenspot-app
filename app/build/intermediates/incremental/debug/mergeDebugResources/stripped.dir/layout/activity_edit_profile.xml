<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_header_primary"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingLeft="16dp"
            android:paddingTop="44dp"
            android:paddingRight="16dp"
            android:paddingBottom="20dp">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_circle_white"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_left"
                app:tint="@color/foreground" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="12dp"
                android:layout_weight="1"
                android:text="@string/edit_profile"
                android:textColor="@color/primary_foreground"
                android:textSize="18sp"
                android:fontFamily="@font/poppins_bold" />

        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:layout_marginTop="-12dp"
            android:layout_marginRight="16dp"
            app:cardBackgroundColor="@color/card"
            app:cardCornerRadius="16dp"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <FrameLayout
                    android:layout_width="96dp"
                    android:layout_height="96dp"
                    android:layout_gravity="center_horizontal">

                    <de.hdodenhof.circleimageview.CircleImageView
                        android:id="@+id/iv_avatar"
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:src="@color/primary_dark" />

                    <TextView
                        android:id="@+id/tv_avatar_letter"
                        android:layout_width="96dp"
                        android:layout_height="96dp"
                        android:background="@color/primary_dark"
                        android:gravity="center"
                        android:text=""
                        android:textColor="@color/primary_foreground"
                        android:textSize="34sp"
                        android:fontFamily="@font/poppins_bold" />

                    <ImageButton
                        android:id="@+id/btn_change_photo"
                        android:contentDescription=""
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:layout_gravity="bottom|end"
                        android:background="@drawable/bg_chip_active"
                        android:padding="7dp"
                        android:src="@drawable/ic_edit"
                        app:tint="@color/primary_foreground" />

                </FrameLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="12dp"
                    android:text="@string/change_photo"
                    android:textColor="@color/primary"
                    android:textSize="13sp"
                    android:fontFamily="@font/poppins_semibold" />

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.HiddenSpot.TextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    app:startIconDrawable="@drawable/ic_profile"
                    app:startIconTint="@color/muted_foreground">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_display_name"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:hint="@string/display_name"
                        android:fontFamily="@font/inter"
                        android:inputType="textPersonName"
                        android:textSize="14sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.HiddenSpot.TextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:startIconDrawable="@android:drawable/sym_action_email"
                    app:startIconTint="#9D9A95">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_email"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:enabled="false"
                        android:fontFamily="@font/inter"
                        android:hint="@string/email_hint"
                        android:inputType="textEmailAddress"
                        android:textSize="14sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.HiddenSpot.TextInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    app:startIconDrawable="@android:drawable/ic_menu_info_details"
                    app:startIconTint="#6A6464">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/et_bio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/inter"
                        android:gravity="top|start"
                        android:hint="@string/bio_hint"
                        android:inputType="textMultiLine"
                        android:minLines="3"
                        android:textSize="14sp" />

                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_save"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:layout_marginTop="24dp"
                    android:backgroundTint="@color/primary"
                    android:text="@string/save_changes"
                    android:textColor="@color/primary_foreground"
                    android:textSize="14sp"
                    android:fontFamily="@font/poppins_semibold"
                    app:cornerRadius="12dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>
